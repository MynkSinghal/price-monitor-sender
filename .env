# ============================================================
# Price Monitor Sender — LOCAL USPROD TEST (Mac)
# Running dashboard2 mock receiver locally on port 8081.
# Both sender and receiver on 192.168.31.152 (this machine).
# ============================================================

# ---- Receiver endpoint ---------------------------------------
RECEIVER_URL=http://127.0.0.1:8080/prices
RECEIVER_TIMEOUT_SECONDS=10

# ---- Sender identity -----------------------------------------
SENDER_HOSTNAME=mac-usprod-local
SENDER_ENV=DEV

# ---- Site ----------------------------------------------------
SENDER_SITE=UKPROD

# ---- Paths ---------------------------------------------------
PRICES_ROOT=/Users/minku/Downloads/Nikhil/prices
STATE_DIR=state_usprod
BACKUP_DIR=backups_usprod
LOG_DIR=logs_usprod

# ---- Scheduling ----------------------------------------------
SEND_MODE=every_minute
SEND_INTERVAL_SECONDS=10

# ---- Business-day timing (UK by default, DST/BST aware) ------
# Every "what date does this instant belong to?" decision uses these.
# Daily reset fires at BUSINESS_DAY_START (interpreted in BUSINESS_TIMEZONE).
# Works correctly even when the host OS clock is in a different zone (e.g.
# USPROD running on US system time — the CSV still says UK time).
BUSINESS_TIMEZONE=Europe/London
BUSINESS_DAY_START=06:00
# BUSINESS_DAY_ANCHOR:
#   "start" — the 06:00→06:00 window starting on date D is labelled D
#             (a price at 04:00 UK on the next morning is still day D).
#   "end"   — the same window is labelled D+1.
BUSINESS_DAY_ANCHOR=start

# ---- Watchdog ------------------------------------------------
HEARTBEAT_MAX_SILENCE_SECONDS=300

# ---- Logging -------------------------------------------------
LOG_LEVEL=INFO

# ---- Active weekdays — include weekend for local testing -----
# 0=Mon 1=Tue 2=Wed 3=Thu 4=Fri 5=Sat 6=Sun
ACTIVE_WEEKDAYS=0,1,2,3,4,5,6
