# ============================================================
# Price Monitor Sender — environment configuration reference
# Copy this file to `.env` and edit.  Every option is listed below
# together with its valid values and the code path that reads it.
# DO NOT commit `.env` to source control (see .gitignore).
# ============================================================
#
# Precedence (ascending):
#   1. config/config.json        — baseline, shared, committed
#   2. config/price_groups.json  — price-group definitions, committed
#   3. .env                      — secrets + per-deployment overrides
# Values here ALWAYS win over config.json.
#


# =========================================================
# 1. Receiver endpoint (provided by automation portal team)
# =========================================================

# Required. Full URL including scheme and path.
# Production example (Linux portal ukvinpbs-101):
#   RECEIVER_URL=http://y.y.y.y/xyz
# Local test (mock receiver in dashboard/mock_receiver.py):
#   RECEIVER_URL=http://127.0.0.1:8765/prices
RECEIVER_URL=http://127.0.0.1:8080/prices

# HTTP request timeout in seconds. Used by requests.post(timeout=…).
# Range: any positive integer. Typical: 5 (local), 15–30 (prod WAN).
RECEIVER_TIMEOUT_SECONDS=15


# =========================================================
# 2. Sender identity (stamped on each transmission)
# =========================================================

# Free-form label the receiver logs next to each payload.
# Must match the real hostname in production so the portal team
# can tell which box sent the CSV.
SENDER_HOSTNAME=ukvinpsp-004

# Free-form tag. Conventional values:
#   PROD  — production (ukvinpsp-004)
#   DR    — disaster-recovery / backup sender
#   UAT   — user acceptance testing
#   DEV   — local developer box
SENDER_ENV=PROD

# REQUIRED. Two-site setup: each host runs the same sender, both POST to the
# same automation endpoint, both send a CSV of EVERY active price group every
# cycle. The site flag tells this sender which side of the world it is on.
#   UKPROD — London/UK production box. Sees only UK-side success.txt files.
#            Rows for USPROD-only jobs are sent with an empty timestamp.
#   USPROD — US production box. Sees only US-side success.txt files (the 11
#            jobs listed in config/config.json → sites.usprod_jobs).
#            Rows for UK-side jobs are sent with an empty timestamp.
# Validated at startup. Anything other than UKPROD / USPROD → exit code 2.
SENDER_SITE=UKPROD


# =========================================================
# 3. Filesystem paths
# =========================================================

# Root folder containing <RANTask>/GetPricesResult/success.txt layout.
# Production (Windows):  C:\Prices
# Local mock (Linux):    ./.smoketest-prices  (relative to project root)
PRICES_ROOT=C:\Prices

# Paths the sender owns. Relative paths resolve against the project root.
# Leave commented to accept defaults.
#CONFIG_DIR=config
#STATE_DIR=state
#BACKUP_DIR=backups
#LOG_DIR=logs


# =========================================================
# 4. Scheduling
# =========================================================

# Controls HOW OFTEN the main loop builds + sends the CSV snapshot.
# Allowed values:
#   every_minute        — fixed cadence of SEND_INTERVAL_SECONDS below.
#                         This is what PROD uses.
#   business_schedule   — staggered cadence defined in
#                         config/config.json → scheduler.business_schedule.
#                         Interpreted in BUSINESS_TIMEZONE; DST/BST aware.
SEND_MODE=every_minute

# Only used when SEND_MODE=every_minute.
# Range: any positive integer (seconds). Typical values:
#   60  — production default (once per minute)
#   4   — local smoke test (see dashboard for near-realtime feedback)
SEND_INTERVAL_SECONDS=60

# =========================================================
# 4b. Business-day timing
# =========================================================
# The "day" the sender talks about is NOT necessarily the OS calendar day.
# It is a 24h window in BUSINESS_TIMEZONE starting at BUSINESS_DAY_START.
# Everything is anchored to this window:
#   * Which CSV file / state.json / backup filename a price's st_ctime is
#     written to.
#   * When the daily reset fires (state cleared, backups rotated, fresh log).
#   * The weekday mask (ACTIVE_WEEKDAYS) is checked against the business day.
#   * success.txt files whose st_ctime predates the current window are
#     ignored as stale (covers the case where the receiver process is
#     restarted but yesterday's success.txt was never deleted).
#
# This means USPROD (running on a US system clock) still rolls over at
# 06:00 UK time exactly like UKPROD does, and the CSV always prints UK
# clock-time regardless of the host OS timezone.

# IANA timezone name. DST/BST aware.
BUSINESS_TIMEZONE=Europe/London

# 24h cutoff (HH:MM in BUSINESS_TIMEZONE). The window opens at this time
# and the next window opens 24h later. Also fires the daily reset.
BUSINESS_DAY_START=06:00

# How to label the 24h window with a calendar date:
#   start — the window that opens at 06:00 on date D is labelled D.
#           A success.txt arriving at 04:30 UK on the next morning is still
#           recorded under D (the next window has not opened yet).
#   end   — the same window is labelled D+1 (downstream sees "today's
#           prices" as the date the window closes).
BUSINESS_DAY_ANCHOR=start


# =========================================================
# 5. Watchdog / self-restart (Q17 locked)
# =========================================================

# If the main loop hasn't ticked for this many seconds, the heartbeat
# file goes stale and the watchdog thread raises SystemExit. Windows
# Task Scheduler then relaunches the process (At-Most-One policy).
# Range: any positive integer (seconds). 300 = 5 minutes.
HEARTBEAT_MAX_SILENCE_SECONDS=300


# =========================================================
# 6. Logging
# =========================================================

# Python logging level. Valid values (case-insensitive):
#   DEBUG     — every filesystem event, every state mutation, every
#               HTTP request/response. Verbose; use only for triage.
#   INFO      — default. One line per cycle, plus state changes and
#               transmission outcomes. Recommended for PROD.
#   WARNING   — only anomalies (retries, transient network issues).
#   ERROR     — only failures (HTTP non-200, IO errors).
#   CRITICAL  — only fatal conditions (unrecoverable shutdown).
# NOTSET is NOT accepted; the code uppercases whatever you pass.
LOG_LEVEL=INFO


# =========================================================
# 7. Active weekdays (Q20 locked: Mon–Fri absolute)
# =========================================================

# Comma-separated list of weekday numbers where the sender is allowed
# to transmit.  Outside the mask the main loop sleeps quietly.
#   0 = Monday
#   1 = Tuesday
#   2 = Wednesday
#   3 = Thursday
#   4 = Friday
#   5 = Saturday
#   6 = Sunday
# Production default = 0,1,2,3,4 (Mon–Fri). Task Scheduler ALSO
# enforces Mon–Fri, so this is belt-and-braces.
# Set to 0,1,2,3,4,5,6 if you want a 7-day test run.
ACTIVE_WEEKDAYS=0,1,2,3,4


# =========================================================
# End of file. Anything not listed above is static runtime
# config and lives in config/config.json:
#   * csv.delimiter / csv.timestamp_format / csv.empty_timestamp_token
#     (the literal we put after the delimiter when this host has not
#     completed a price group yet — defaults to "" / blank;
#     change to "pending" or "NA" if the receiver wants a sentinel.)
#   * sites.usprod_jobs   (the 11 RANTask folders that live on USPROD)
#   * scheduler.business_schedule windows, log rotation sizes, etc.
# Touch that file only if you need to change the wire format.
# =========================================================
